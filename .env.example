# Commons — environment. Copy to `.env` and fill in. NEVER commit `.env`.

# The one connection string that decides the database engine (ARCHITECTURE.md §5):
#   postgres://user:pass@host:5432/commons   -> Postgres (default; growing orgs)
#   file:./data/commons.db                   -> SQLite  (tiny orgs; wired in M1)
DATABASE_URL=postgres://commons:commons@localhost:5432/commons
